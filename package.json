{
  "name": "invox",
  "version": "0.0.1",
  "description": "ACP-compatible agent server with pluggable transports (stdio + WebSocket) and OpenAI-compatible LLM backend",
  "type": "module",
  "bin": {
    "invox": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "restart": "bash scripts/dev-restart.sh"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "acp",
    "agent-client-protocol",
    "zed",
    "agent",
    "llm",
    "openai"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@types/ws": "^8.18.1",
    "@vscode/ripgrep": "^1.18.0",
    "@zed-industries/agent-client-protocol": "^0.4.5",
    "fast-glob": "^3.3.3",
    "openai": "^6.39.1",
    "ws": "^8.21.0"
  }
}
